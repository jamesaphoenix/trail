# Rust build output (root + standalone binding workspaces under bindings/*)
target/

# trail runtime state (the SQLite DB lives here; never commit it)
.trail/

# Note: .trail.toml IS meant to be committed; only the state dir above is ignored.

# Python (wrappers/python, bindings/python)
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/

# Node (wrappers/typescript, bindings/node)
node_modules/
# napi build artifacts (regenerated by `napi build`)
bindings/node/*.node
bindings/node/index.js
bindings/node/index.d.ts

# macOS
.DS_Store
